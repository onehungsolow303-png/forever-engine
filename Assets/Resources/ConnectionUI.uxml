<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:VisualElement name="overlay" style="position: absolute; left: 0; top: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.85); align-items: center; justify-content: center;">
        <ui:VisualElement style="background-color: rgb(30,30,30); padding: 40px; border-radius: 8px; min-width: 300px; align-items: center;">
            <ui:Label name="status-text" text="Connecting to server..." style="color: rgb(200,200,200); font-size: 18px; margin-bottom: 16px;" />
            <ui:Label name="detail-text" text="" style="color: rgb(140,140,140); font-size: 12px;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
